{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish HotelJTech.Web/HotelJTech.Web.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "dotnet out/HotelJTech.Web.dll",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100
  }
}

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotelJTech.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F7F1E8">

    <ScrollView>
        <Grid RowDefinitions="Auto,*"
              Padding="24"
              RowSpacing="24">

            <VerticalStackLayout Grid.Row="0"
                                 Spacing="6">
                <Label Text="Hotel JTech"
                       FontFamily="KalamBold"
                       FontSize="42"
                       TextColor="#244034"
                       HorizontalTextAlignment="Center" />

                <Label Text="Conforto, descanso e praticidade para sua estadia"
                       FontSize="16"
                       TextColor="#6A5B48"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="1"
                                 Spacing="18"
                                 VerticalOptions="Center">

                <Image Source="quarto.png.webp"
                       HeightRequest="220"
                       Aspect="AspectFit"
                               SemanticProperties.Description="Ilustracao da fachada do hotel" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            Stroke="#E3D7C8"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="#FFFDF8"
                            Padding="10">
                        <VerticalStackLayout Spacing="6">
                            <Image Source="hotel.png.webp"
                                   HeightRequest="120"
                                   Aspect="AspectFit"
                                   SemanticProperties.Description="Ilustracao de uma suite do hotel" />
                            <Label Text="Suites confortaveis"
                                   FontAttributes="Bold"
                                   TextColor="#244034"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            Stroke="#E3D7C8"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="#FFFDF8"
                            Padding="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Diarias sob medida"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   TextColor="#244034"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Informe hospedes, periodo e acomodacao para calcular o valor."
                                   FontSize="13"
                                   TextColor="#6A5B48"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Button Text="Calcular diaria"
                        FontAttributes="Bold"
                        FontSize="18"
                        BackgroundColor="#2F6B4F"
                        TextColor="White"
                        Clicked="OnCalcularDiariaClicked" />
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
